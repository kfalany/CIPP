{
  "routes": [
    {
      "route": "/static/*",
      "headers": {
        "cache-control": "must-revalidate, max-age=15770000"
      }
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/aad"
    },
    {
      "route": "/.auth/login/twitter",
      "statusCode": 404
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/LogoutRedirect"
    },
    {
      "route": "/apple-touch-icon.png",
      "allowedRoles": ["admin", "readonly", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "/favicon-32x32.png",
      "allowedRoles": ["admin", "readonly", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "/favico.ico",
      "allowedRoles": ["admin", "readonly", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "/api/ExecSAMSetup",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/AddStandardsDeploy",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/LogoutRedirect",
      "allowedRoles": ["admin", "readonly", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "/404",
      "allowedRoles": ["admin", "readonly", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "/api/RemoveStandard",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/add*",
      "allowedRoles": ["admin", "level2", "level1"]
    },
    {
      "route": "/api/edit*",
      "allowedRoles": ["admin", "level2", "level1"]
    },
    {
      "route": "/api/ExecSendPush",
      "allowedRoles": ["admin", "level2", "level1"]
    },
    {
      "route": "/api/ExecExcludeTenant",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/Exec*",
      "allowedRoles": ["admin", "level2", "level1"]
    },
    {
      "route": "/api/Remove*",
      "allowedRoles": ["admin", "level2", "level1"]
    },
    {
      "route": "/cipp/*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/tenant/standards/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/tenant/administration/alertswizard/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/tenant/conditional/deploy*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/tenant/conditional/add-template*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/endpoint/applications/add*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/endpoint/autopilot/add-status-page*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/endpoint/MEM/add-policy*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/email/transport/deploy-rules*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/email/connectors/deploy-connector*",
      "allowedRoles": ["admin", "level2"]
    },
     {
      "route": "/email/spamfilter/deploy*",
      "allowedRoles": ["admin", "level2"]
    },
    {
      "route": "/",
      "allowedRoles": ["admin", "readonly", "reader", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "/api/Public*",
      "allowedRoles": ["admin", "readonly", "reader", "authenticated", "anonymous", "level2", "level1"]
    },
    {
      "route": "*",
      "allowedRoles": ["admin", "readonly", "reader", "level2", "level1"]
    }
  ],
  "navigationFallback": {
    "rewrite": "index.html",
    "exclude": ["/static/*.{png,jpg,gif}", "/css/*"]
  },
  "responseOverrides": {
    "401": {
      "rewrite": "/401"
    },
    "403": {
      "rewrite": "/403"
    },
    "404": {
      "rewrite": "/404"
    }
  },
  "globalHeaders": {
    "content-security-policy": "default-src https: 'unsafe-eval' 'unsafe-inline'; object-src 'none'; img-src 'self' data: *"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
